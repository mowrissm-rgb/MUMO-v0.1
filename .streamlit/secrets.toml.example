# Copy this file to .streamlit/secrets.toml and fill in real values.
# secrets.toml is already in .gitignore — never commit real keys.

# ── Supabase (login + persistent chat history) ──
# Get these from your Supabase project: Settings → API.
#   SUPABASE_URL  = the "Project URL"
#   SUPABASE_KEY  = the "anon / public" key (NOT the service_role key)
# Then run supabase_schema.sql once in the Supabase SQL editor.
SUPABASE_URL = "https://xxxxxxxxxxxx.supabase.co"
SUPABASE_KEY = "your-anon-public-key"

# ── LLM (existing — unrelated to Supabase) ──
[llm]
provider = "groq"          # or "openai" / "anthropic" / "gemini"
api_key = "your-llm-api-key"
